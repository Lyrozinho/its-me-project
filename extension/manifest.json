{
  "manifest_version": 3,
  "name": "Love Hyro",
  "version": "1.0.0",
  "description": "Congele seus créditos com a extensão Love Hyro.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
